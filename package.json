{
  "name": "smartshell-ai",
  "version": "1.0.0",
  "description": "🧠 SmartShell AI - 轻量级跨平台终端AI命令助手，让自然语言秒变Shell命令",
  "main": "dist/index.js",
  "bin": {
    "smartshell": "dist/index.js",
    "ss": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "package": "pkg . --out-path=bin/",
    "package:all": "pkg . --targets node18-linux-x64,node18-macos-x64,node18-win-x64 --out-path=bin/"
  },
  "keywords": [
    "ai",
    "cli",
    "terminal",
    "shell",
    "command",
    "assistant",
    "openai",
    "claude",
    "gemini",
    "ollama"
  ],
  "author": "gitstq",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^0.0.0",
    "@ai-sdk/google": "^0.0.0",
    "@ai-sdk/openai": "^0.0.0",
    "@anthropic-ai/sdk": "^0.101.0",
    "@google/generative-ai": "^0.24.1",
    "@types/better-sqlite3": "^7.6.13",
    "ai": "^3.0.0",
    "better-sqlite3": "^9.4.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.0",
    "openai": "^4.104.0",
    "ora": "^8.0.0",
    "ts-jest": "^29.4.11"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "pkg": "^5.8.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "node_modules/better-sqlite3/build/Release/better_sqlite3.node"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-win-x64"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
